{
  "extends": [
    "stylelint-config-standard"
  ],
  "overrides": [
    {
      "files": ["src/**/*.css"],
      "rules": {
        "at-rule-no-unknown": [
          true,
          {
            "ignoreAtRules": ["tailwind", "apply", "responsive", "screen", "layer"]
          }
        ]
      }
    }
  ],
  "rules": {
    "at-rule-no-unknown": null,
    "property-no-unknown": null,
    "selector-pseudo-element-no-unknown": [
      true,
      {
        "ignorePseudoElements": ["v-deep", "ng-deep"]
      }
    ]
  }
}
