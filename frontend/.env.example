# Frontend Environment Configuration
# For PRODUCTION deployment, use .env.production.example as your template
# Copy it to .env.production and update with production values

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=30000

# Socket.io Configuration
REACT_APP_SOCKET_URL=http://localhost:5000
REACT_APP_SOCKET_RECONNECTION=true
REACT_APP_SOCKET_RECONNECTION_DELAY=1000
REACT_APP_SOCKET_RECONNECTION_DELAY_MAX=5000
REACT_APP_SOCKET_RECONNECTION_ATTEMPTS=5

# Application Configuration
REACT_APP_APP_NAME=Online Attendance System
REACT_APP_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_ERROR_TRACKING=true
REACT_APP_ENABLE_PERFORMANCE_MONITORING=true

# Authentication
REACT_APP_TOKEN_STORAGE_KEY=attendanceSystemToken
REACT_APP_USER_STORAGE_KEY=attendanceSystemUser

# Toast Notifications
REACT_APP_TOAST_POSITION=bottom-right
REACT_APP_TOAST_AUTO_CLOSE=5000

# Date Format
REACT_APP_DATE_FORMAT=DD/MM/YYYY
REACT_APP_TIME_FORMAT=HH:mm:ss

# File Upload
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf,.xlsx,.xls,.csv

# Password Requirements (must match backend)
REACT_APP_PASSWORD_MIN_LENGTH=8
REACT_APP_PASSWORD_REQUIRE_UPPERCASE=true
REACT_APP_PASSWORD_REQUIRE_LOWERCASE=true
REACT_APP_PASSWORD_REQUIRE_NUMBERS=true
REACT_APP_PASSWORD_REQUIRE_SPECIAL=true

# API Endpoints (optional - for custom routing)
REACT_APP_AUTH_ENDPOINT=/auth
REACT_APP_EMPLOYEES_ENDPOINT=/employees
REACT_APP_ATTENDANCE_ENDPOINT=/attendance
REACT_APP_LEAVES_ENDPOINT=/leaves
REACT_APP_DEPARTMENTS_ENDPOINT=/departments
REACT_APP_NOTICES_ENDPOINT=/notices
REACT_APP_DASHBOARD_ENDPOINT=/dashboard

# Language Configuration
REACT_APP_DEFAULT_LANGUAGE=hi
REACT_APP_SUPPORTED_LANGUAGES=hi,en

# Theme Configuration
REACT_APP_PRIMARY_COLOR=#667eea
REACT_APP_SECONDARY_COLOR=#764ba2
REACT_APP_DANGER_COLOR=#ef4444
REACT_APP_SUCCESS_COLOR=#22c55e

# Sentry Configuration (Optional)
REACT_APP_SENTRY_DSN=

# Vercel Analytics
REACT_APP_VERCEL_ENV=development
