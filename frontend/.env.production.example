# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION - FRONTEND
# =============================================================================
# This is a TEMPLATE - DO NOT commit actual values to git
# Copy this file to .env.production and fill in with REAL production values
# =============================================================================

# =============================================================================
# REACT ENVIRONMENT
# =============================================================================
REACT_APP_ENV=production

# =============================================================================
# API CONFIGURATION (REQUIRED)
# =============================================================================
# Your production backend API URL
# Example: https://api.yourdomain.com
REACT_APP_API_URL=https://api.yourdomain.com/api

# =============================================================================
# SOCKET.IO CONFIGURATION (REQUIRED)
# =============================================================================
# Your production backend server URL (for real-time updates)
# Example: https://api.yourdomain.com
REACT_APP_SOCKET_URL=https://api.yourdomain.com

# =============================================================================
# SENTRY ERROR TRACKING (Recommended for Production)
# =============================================================================
# Sentry DSN for frontend error tracking
# Sign up at https://sentry.io
REACT_APP_SENTRY_DSN=your_production_frontend_sentry_dsn

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# Vercel Analytics for performance monitoring
REACT_APP_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# Enable/disable features in production
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_EXPORT=true
REACT_APP_ENABLE_DEBUG=false

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================
# These are automatically set by build process
# Leave as default for production builds
CI=false
GENERATE_SOURCEMAP=false

# =============================================================================
# TIMEOUT CONFIGURATION
# =============================================================================
# API request timeout in milliseconds
REACT_APP_API_TIMEOUT=30000

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to production, verify:
#
# ✅ REACT_APP_API_URL points to production backend
# ✅ REACT_APP_SOCKET_URL points to production server
# ✅ REACT_APP_SENTRY_DSN configured for monitoring
# ✅ All required variables filled (no placeholders)
# ✅ REACT_APP_ENABLE_DEBUG=false
# ✅ GENERATE_SOURCEMAP=false (for security)
# ✅ Built with: npm run build
# ✅ Deployed to production hosting (Vercel, Render, etc.)
# ✅ SSL/TLS certificate installed
# ✅ Domain properly configured
#
# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 1. Build for production: npm run build
# 2. Set .env.production before building
# 3. Never commit .env files to git
# 4. Use hosting platform's environment variable management
# 5. Monitor frontend errors in Sentry dashboard
# 6. Test all features after deployment
# 7. Monitor performance metrics in Vercel Analytics
#
# =============================================================================
