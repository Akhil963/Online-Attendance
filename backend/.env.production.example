# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# This is a TEMPLATE - DO NOT commit actual values to git
# Copy this file to .env.production and fill in with REAL production values
# IMPORTANT: Never use development values in production!
# =============================================================================

# =============================================================================
# NODE ENVIRONMENT - MUST BE PRODUCTION
# =============================================================================
NODE_ENV=production

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=5000
HOST=0.0.0.0

# =============================================================================
# DATABASE CONFIGURATION (MongoDB Atlas - REQUIRED)
# =============================================================================
# Use MongoDB Atlas for production (https://www.mongodb.com/cloud/atlas)
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/attendance_system?retryWrites=true&w=majority

# =============================================================================
# JWT CONFIGURATION (REQUIRED - Generate Strong Random String)
# =============================================================================
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Minimum 32 characters, must be unique, NEVER use development key
JWT_SECRET=generate_a_strong_random_string_at_least_32_characters
JWT_EXPIRE=7d

# =============================================================================
# ADMIN REGISTRATION CODE (REQUIRED - Generate New Value)
# =============================================================================
# Generate using: node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
# Keep this secret - only share during initial admin setup
ADMIN_REGISTRATION_CODE=change_this_strong_code

# =============================================================================
# FRONTEND CONFIGURATION - CORS (REQUIRED)
# =============================================================================
# Your production frontend URL(s)
# Use comma-separated values for multiple origins
# Example: https://yourdomain.com,https://www.yourdomain.com
CLIENT_URL=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# EMAIL CONFIGURATION - SENDGRID (REQUIRED)
# =============================================================================
# SendGrid Setup (https://sendgrid.com):
# 1. Sign up for account
# 2. Verify sender domain (Settings > Sender Authentication)
# 3. Create API key (Settings > API Keys)
# 4. Add DNS records: SPF, DKIM, CNAME
# Never use free tier in production - use paid SendGrid account

SENDGRID_API_KEY=your_sendgrid_production_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Online Attendance System
ADMIN_REPLY_EMAIL=support@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
REPORT_EMAIL=admin@yourdomain.com
COMPANY_NAME=Your Company Name

# =============================================================================
# TWILIO CONFIGURATION (OPTIONAL - for SMS notifications)
# =============================================================================
# Twilio Setup (https://www.twilio.com):
# 1. Create account on Twilio
# 2. Get Account SID and Auth Token from console
# 3. Buy phone number or use trial
# Leave empty to disable SMS features

TWILIO_ACCOUNT_SID=your_production_twilio_sid
TWILIO_AUTH_TOKEN=your_production_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# ERROR TRACKING - SENTRY (OPTIONAL - Recommended for Production)
# =============================================================================
# Sentry Setup (https://sentry.io):
# 1. Sign up for account
# 2. Create new project (Node.js)
# 3. Copy DSN URL
# This helps monitor errors in production

SENTRY_DSN=your_production_sentry_dsn

# =============================================================================
# SESSION CONFIGURATION (REQUIRED - Generate Strong Random String)
# =============================================================================
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=generate_a_strong_random_string_for_session_secret

# =============================================================================
# COOKIE SECURITY (REQUIRED for HTTPS)
# =============================================================================
# Must be true in production (requires HTTPS)
# Set to false only if not using HTTPS (not recommended)
SECURE_COOKIES=true

# =============================================================================
# RATE LIMITING (Stricter in Production)
# =============================================================================
# Window: 900000ms = 15 minutes
# Max requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_VERSION=v1
LOG_LEVEL=warn

# =============================================================================
# SECURITY (HTTPS Required in Production)
# =============================================================================
# HTTPS must be enabled in production
# Use reverse proxy (Nginx) or load balancer with SSL
ALLOW_INSECURE_ORIGIN=false

# =============================================================================
# DATABASE CONNECTION POOL (Production Settings)
# =============================================================================
# Increased pool size for production traffic
DB_POOL_SIZE=20
DB_TIMEOUT=5000

# =============================================================================
# FRONTEND URL (for Socket.io)
# =============================================================================
FRONTEND_URL=https://yourdomain.com

# =============================================================================
# SOCKET.IO CONFIGURATION
# =============================================================================
SOCKET_ENABLE_CORS=true
SOCKET_CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# AUDIT LOGGING (Recommended for Production)
# =============================================================================
ENABLE_AUDIT_LOGGING=true

# =============================================================================
# EMAIL ALLOWLIST (Optional - Safety Feature)
# =============================================================================
# Comma-separated list of emails that CANNOT receive emails
# Useful to blacklist certain addresses
# Example: BLOCKED_EMAIL_RECIPIENTS=noreply@example.com,test@example.com
BLOCKED_EMAIL_RECIPIENTS=

# =============================================================================
# PASSWORD RESET CONFIGURATION
# =============================================================================
PASSWORD_RESET_TOKEN_EXPIRY=24h
PASSWORD_RESET_MAX_ATTEMPTS_PER_24H=3

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for API requests
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to production, verify:
#
# ✅ NODE_ENV=production
# ✅ All required variables filled (no placeholders)
# ✅ JWT_SECRET and SESSION_SECRET are strong random strings
# ✅ MONGODB_URI uses MongoDB Atlas with strong credentials
# ✅ SENDGRID_API_KEY is valid and from paid account
# ✅ SECURE_COOKIES=true (requires HTTPS)
# ✅ CLIENT_URL points to production frontend domain
# ✅ SENTRY_DSN configured for error tracking
# ✅ Rate limiting configured appropriately
# ✅ Email domain verified in SendGrid
# ✅ SSL/TLS certificate installed
# ✅ Database backups configured
# ✅ Monitoring set up (logging, alerts)
#
# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 1. Never commit .env files to git
# 2. Use environment variables from hosting platform (Render, Heroku, etc.)
# 3. Rotate credentials every 3 months
# 4. Keep backup of old credentials for rollback
# 5. Monitor logs for errors and suspicious activity
# 6. Test all features before going live
# 7. Have rollback plan ready
#
# =============================================================================
