# Backend Environment Configuration
# This is a TEMPLATE for DEVELOPMENT only
# For PRODUCTION, see .env.production.example

# ============================================================================
# CHOOSE YOUR ENVIRONMENT
# ============================================================================
# Development: Copy this file to .env and use development values
# Production: Copy .env.production.example to .env and use production values
# ============================================================================

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/attendance_system
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/attendance_system?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_please_change_this_in_production_12345
JWT_EXPIRE=7d

# Admin Registration
ADMIN_REGISTRATION_CODE=ADMIN_SECRET_2024

# Email Configuration (SendGrid is recommended for better deliverability)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Online Attendance System
ADMIN_REPLY_EMAIL=support@yourdomain.com
ADMIN_EMAIL=admin@company.com
COMPANY_NAME=Online Attendance System

# Note: For SendGrid:
# 1. Sign up at https://sendgrid.com/
# 2. Create API key from Settings > API Keys
# 3. Verify your sender domain for better deliverability
# 4. Add SPF, DKIM, and CNAME records to your domain

# Email Allowlist (Optional - restrict delivery for testing)
# ALLOWED_EMAIL_RECIPIENTS=test@example.com,admin@example.com

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# Sentry Configuration (Optional - for error tracking)
SENTRY_DSN=

# Twilio Configuration (Optional - for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Socket.io Configuration
SOCKET_ENABLE_CORS=true
SOCKET_CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
ENABLE_AUDIT_LOGGING=true

# Security
ENABLE_HTTPS=false
# Set to true in production and provide certificate paths
TLS_CERT_PATH=
TLS_KEY_PATH=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Session Configuration
SESSION_SECRET=your_session_secret_key_change_this

# Password Reset Configuration
PASSWORD_RESET_TOKEN_EXPIRY=24h
PASSWORD_RESET_MAX_ATTEMPTS_PER_24H=3

# Attendance location settings
# Leave blank to allow any location, or set values to enforce an office geofence.
OFFICE_LATITUDE=
OFFICE_LONGITUDE=
OFFICE_RADIUS_METERS=200

# Email Allowlist
# Comma-separated list of email addresses that are allowed to receive emails.
# Leave empty (or remove) to allow delivery to ALL addresses (production behaviour).
# In development/staging, set this to your own email(s) so real users never receive test emails.
# Example: ALLOWED_EMAIL_RECIPIENTS=dev@example.com,test@example.com
ALLOWED_EMAIL_RECIPIENTS=
